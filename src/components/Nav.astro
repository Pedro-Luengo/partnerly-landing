---
import type { Translations } from '../i18n/en';
import type { Locale } from '../i18n/index';

interface Props { t: Translations; locale: Locale; }
const { t, locale } = Astro.props;
const altLocale = locale === 'en' ? 'es' : 'en';
---

<nav>
  <div class="wrap nav-in">
    <a href={`/${locale}`} class="brand" aria-label="Partnerly home">
      <!-- Horizontal logo SVG inlined, coloured to match brand -->
      <svg width="140" height="42" viewBox="0 0 881 261" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
        <defs>
          <linearGradient id="nav-g" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="#FFB154"/>
            <stop offset="1" stop-color="#FF8A5B"/>
          </linearGradient>
          <radialGradient id="nav-glowR">
            <stop offset="0" stop-color="#FF8A5B" stop-opacity="0.26"/>
            <stop offset="0.55" stop-color="#FF8A5B" stop-opacity="0.12"/>
            <stop offset="1" stop-color="#FF8A5B" stop-opacity="0"/>
          </radialGradient>
        </defs>
        <!-- Mascot head -->
        <g transform="translate(115.8,130.6) scale(1.14)">
          <circle cx="0" cy="-6" r="100" fill="url(#nav-glowR)"/>
          <path d="M0,-86 C26,-70 60,-46 62,-6 C64,40 36,66 0,66 C-36,66 -64,40 -62,-6 C-60,-46 -26,-70 0,-86 Z" fill="url(#nav-g)"/>
          <ellipse cx="-34" cy="6" rx="9" ry="6" fill="#FF5E52" opacity="0.30"/>
          <ellipse cx="34" cy="6" rx="9" ry="6" fill="#FF5E52" opacity="0.30"/>
          <ellipse cx="-22" cy="-14" rx="11" ry="15" fill="#2E2640"/>
          <circle cx="-26" cy="-20" r="4" fill="#FFF" opacity="0.95"/>
          <ellipse cx="22" cy="-14" rx="11" ry="15" fill="#2E2640"/>
          <circle cx="18" cy="-20" r="4" fill="#FFF" opacity="0.95"/>
          <path d="M-17,22 Q0,37 17,22" stroke="#2E2640" stroke-width="4" fill="none" stroke-linecap="round"/>
        </g>
        <!-- Wordmark -->
        <g transform="translate(233.6,65.7)">
          <g fill="#2E2640" transform="translate(0,100)">
            <path transform="translate(0.00,0) scale(0.1342,-0.1342)" d="M66 0V745H352Q429 745 488.5 718.0Q548 691 582.0 638.0Q616 585 616 507Q616 431 581.5 378.0Q547 325 487.5 297.5Q428 270 352 270H221V0ZM221 405H353Q402 405 431.5 433.0Q461 461 461 507Q461 554 431.5 582.0Q402 610 353 610H221Z"/>
            <path transform="translate(87.11,0) scale(0.1342,-0.1342)" d="M224 -12Q136 -12 84.5 30.0Q33 72 33 146Q33 215 81.0 260.0Q129 305 227 321L378 345V360Q378 391 353.5 412.0Q329 433 287 433Q247 433 216.5 411.0Q186 389 172 353L52 410Q76 478 141.5 518.0Q207 558 294 558Q363 558 416.0 533.0Q469 508 498.5 463.5Q528 419 528 360V0H388V51Q326 -12 224 -12ZM188 151Q188 126 207.0 112.0Q226 98 254 98Q310 98 344.0 133.0Q378 168 378 218V235L254 213Q222 207 205.0 192.5Q188 178 188 151Z"/>
            <path transform="translate(165.37,0) scale(0.1342,-0.1342)" d="M55 0V546H195V464Q216 515 254.5 533.5Q293 552 343 552H375V422H328Q273 422 239.0 388.5Q205 355 205 294V0Z"/>
            <path transform="translate(217.18,0) scale(0.1342,-0.1342)" d="M318 -6Q219 -6 164.5 47.5Q110 101 110 197V416H18V546H23Q110 546 110 630V670H260V546H388V416H260V207Q260 124 353 124Q367 124 388 127V0Q373 -2 354.0 -4.0Q335 -6 318 -6Z"/>
            <path transform="translate(273.69,0) scale(0.1342,-0.1342)" d="M55 0V546H195V479Q216 519 256.0 538.5Q296 558 348 558Q410 558 456.5 532.0Q503 506 529.0 459.5Q555 413 555 351V0H405V319Q405 366 377.0 394.5Q349 423 305 423Q261 423 233.0 394.5Q205 366 205 319V0Z"/>
            <path transform="translate(354.09,0) scale(0.1342,-0.1342)" d="M318 -12Q231 -12 167.0 26.5Q103 65 68.0 130.0Q33 195 33 274Q33 356 69.5 420.0Q106 484 168.0 521.0Q230 558 308 558Q395 558 455.0 522.0Q515 486 546.5 425.5Q578 365 578 289Q578 273 576.5 257.5Q575 242 571 231H189Q195 180 230.0 149.0Q265 118 320 118Q360 118 388.5 134.0Q417 150 433 178L553 121Q528 61 465.0 24.5Q402 -12 318 -12ZM308 438Q264 438 233.5 413.0Q203 388 192 341H419Q414 384 384.0 411.0Q354 438 308 438Z"/>
            <path transform="translate(436.11,0) scale(0.1342,-0.1342)" d="M55 0V546H195V464Q216 515 254.5 533.5Q293 552 343 552H375V422H328Q273 422 239.0 388.5Q205 355 205 294V0Z"/>
            <path transform="translate(487.92,0) scale(0.1342,-0.1342)" d="M55 0V757H205V0Z"/>
            <path transform="translate(522.82,0) scale(0.1342,-0.1342)" d="M140 -220Q116 -220 93.5 -216.0Q71 -212 54 -203V-80Q86 -90 122 -90Q166 -90 185.0 -69.5Q204 -49 216 -23L226 0L11 546H172L301 195L430 546H591L357 -51Q290 -220 140 -220Z"/>
          </g>
        </g>
      </svg>
    </a>

    <div class="nav-right">
      <a href={`/${altLocale}`} class="lang-btn" aria-label={t.nav.langSwitchLabel} data-lang-switch={altLocale}>
        {t.nav.langSwitch}
      </a>
      <button
        id="nav-cta"
        class="nav-cta"
        data-label-default={t.nav.cta}
        data-label-signed={t.nav.ctaSigned}
        onclick="document.getElementById('email-top').focus()"
      >
        {t.nav.cta}
      </button>
    </div>
  </div>
</nav>

<script>
  const SIGNUP_KEY = 'pl_signup';

  function setSignedState() {
    const btn = document.getElementById('nav-cta') as HTMLButtonElement | null;
    if (!btn) return;
    const label = btn.dataset.labelSigned ?? btn.dataset.labelDefault ?? '';
    btn.textContent = label;
    btn.classList.add('nav-cta--signed');
    btn.onclick = null;
  }

  if (localStorage.getItem(SIGNUP_KEY)) setSignedState();

  window.addEventListener('partnerly:signup', () => {
    localStorage.setItem(SIGNUP_KEY, '1');
    setSignedState();
  });

  // Scroll-hide nav (shows on scroll up, hides on scroll down past 80px)
  let lastY = window.scrollY;
  const navEl = document.querySelector('nav') as HTMLElement | null;
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (navEl) {
      if (y > lastY && y > 80) navEl.classList.add('nav--hidden');
      else navEl.classList.remove('nav--hidden');
    }
    lastY = y;
  }, { passive: true });
</script>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(255, 247, 240, .72);
    border-bottom: 1px solid var(--divider);
    transition: transform .3s cubic-bezier(.4, 0, .2, 1);
  }
  nav.nav--hidden { transform: translateY(-100%); }

  .nav-in {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 74px;
  }

  .brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand svg { display: block; }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .lang-btn {
    font-family: inherit;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: .4px;
    color: var(--text-2);
    text-decoration: none;
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid var(--divider);
    background: transparent;
    transition: background .18s, color .18s;
    cursor: pointer;
  }
  .lang-btn:hover { background: rgba(46,38,64,.06); color: var(--plum); }

  .nav-cta {
    font-family: inherit;
    font-weight: 700;
    font-size: 14px;
    white-space: nowrap;
    padding: 12px 22px;
    border-radius: 999px;
    background: var(--grad);
    color: var(--cream);
    border: none;
    cursor: pointer;
    box-shadow: var(--shadow-glow);
    transition: transform .2s cubic-bezier(.34, 1.56, .64, 1);
  }
  .nav-cta:hover { transform: translateY(-2px) scale(1.02); }

  .nav-cta--signed {
    background: rgba(127, 181, 166, .18);
    color: var(--sage-ink);
    box-shadow: none;
    cursor: default;
    font-size: 13px;
  }
  .nav-cta--signed:hover { transform: none; }

  @media (max-width: 480px) {
    .lang-btn { display: none; }
    .nav-cta { font-size: 13px; padding: 11px 18px; }
  }
</style>
