---
import type { Translations } from '../i18n/en';
import type { Locale } from '../i18n/index';

interface Props {
  t: Translations;
  locale: Locale;
  id: string;       // unique suffix: 'top' | 'bot'
  centered?: boolean;
}
const { t, locale, id, centered = false } = Astro.props;
const inputId = `email-${id}`;
const okId = `ok-${id}`;
---

<div class:list={['form-wrap', centered && 'centered']}>
  <div class="form" id={`form-${id}`}>
    <div class="field">
      <input
        id={inputId}
        type="email"
        inputmode="email"
        placeholder={t.hero.inputPlaceholder}
        aria-label="Email"
        autocomplete="email"
      />
      <button type="button" data-form-id={id}>
        {t.hero.cta}
      </button>
    </div>
    <p class="note">{id === 'top' ? t.hero.note : t.finalCta.note}</p>
  </div>

  <div class="success" id={okId} role="status" aria-live="polite">
    <h3>
      <span class="check" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </span>
      {t.success.heading}
    </h3>
    <p class="success-body">{t.success.body}</p>
    <p class="success-body already" style="display:none">{t.success.alreadyBody}</p>
  </div>

  <p class="field-error" id={`err-${id}`} role="alert" aria-live="polite" style="display:none">
    Something went wrong — please try again.
  </p>
</div>

<script>
  function getSource(): string {
    const p = new URLSearchParams(window.location.search);
    return p.get('utm_source') || p.get('ref') || 'direct';
  }

  function getLocale(): string {
    const m = window.location.pathname.match(/^\/(en|es)/);
    return m ? m[1] : 'en';
  }

  function showError(formId: string) {
    const el = document.getElementById(`err-${formId}`) as HTMLElement | null;
    if (!el) return;
    el.style.display = 'block';
    setTimeout(() => { el.style.display = 'none'; }, 6000);
  }

  function showSuccess(formId: string, already = false) {
    const okId = `ok-${formId}`;
    const ok = document.getElementById(okId);
    if (!ok) return;
    const form = document.getElementById(`form-${formId}`);
    if (form) form.style.display = 'none';
    const errEl = document.getElementById(`err-${formId}`);
    if (errEl) errEl.style.display = 'none';

    ok.classList.add('on');
    if (already) {
      (ok.querySelector('.success-body:not(.already)') as HTMLElement | null)?.style.setProperty('display', 'none');
      const alreadyEl = ok.querySelector('.already') as HTMLElement | null;
      if (alreadyEl) alreadyEl.style.display = '';
    }
    ok.scrollIntoView({ behavior: 'smooth', block: 'center' });
    window.dispatchEvent(new CustomEvent('partnerly:signup', { detail: { already } }));
  }

  async function handleJoin(formId: string) {
    const inputEl = document.getElementById(`email-${formId}`) as HTMLInputElement | null;
    if (!inputEl) return;

    const email = inputEl.value.trim();
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      inputEl.focus();
      inputEl.style.boxShadow = '0 0 0 2px var(--glow-coral)';
      setTimeout(() => { inputEl.style.boxShadow = ''; }, 1200);
      return;
    }

    const btn = document.querySelector(`[data-form-id="${formId}"]`) as HTMLButtonElement | null;
    if (btn) { btn.disabled = true; btn.style.opacity = '.7'; }

    try {
      const res = await fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: getSource(), locale: getLocale() }),
      });

      const data = await res.json() as { ok: boolean; already?: boolean; error?: string; code?: string };

      if (data.ok) {
        showSuccess(formId, data.already);
      } else {
        console.error('[Partnerly] /api/waitlist error:', data.error, data.code);
        if (btn) { btn.disabled = false; btn.style.opacity = ''; }
        showError(formId);
      }
    } catch (err) {
      console.error('[Partnerly] fetch error:', err);
      if (btn) { btn.disabled = false; btn.style.opacity = ''; }
      showError(formId);
    }
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-form-id]') as HTMLElement | null;
    if (btn) {
      const id = btn.getAttribute('data-form-id');
      if (id) handleJoin(id);
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return;
    const input = e.target as HTMLElement;
    if (input.tagName === 'INPUT' && input.id?.startsWith('email-')) {
      handleJoin(input.id.replace('email-', ''));
    }
  });
</script>

<style>
  .form-wrap { width: 100%; }
  .form-wrap.centered .form,
  .form-wrap.centered .success { margin-inline: auto; }

  .form { max-width: 490px; }

  .field {
    display: flex;
    gap: 10px;
    background: var(--surface);
    padding: 9px;
    border-radius: 999px;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--divider);
  }

  .field input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    background: transparent;
    font-family: inherit;
    font-size: 16px;
    font-weight: 500;
    padding: 0 22px;
    color: var(--plum);
    transition: box-shadow .2s;
  }
  .field input::placeholder { color: var(--text-3); }

  .field button {
    font-family: inherit;
    font-weight: 700;
    font-size: 15px;
    white-space: nowrap;
    padding: 16px 30px;
    border: none;
    border-radius: 999px;
    background: var(--grad);
    color: var(--cream);
    cursor: pointer;
    box-shadow: var(--shadow-glow);
    transition: transform .2s cubic-bezier(.34, 1.56, .64, 1), opacity .2s;
    flex-shrink: 0;
  }
  .field button:hover { transform: scale(1.03); }
  .field button:active { transform: scale(.96); }
  .field button:disabled { cursor: not-allowed; }

  .note {
    font-size: 13px;
    color: var(--text-3);
    margin-top: 18px;
    padding-left: 8px;
    font-weight: 500;
  }
  .form-wrap.centered .note { text-align: center; padding-left: 0; }

  .success {
    display: none;
    max-width: 490px;
    background: var(--surface);
    border: 1px solid var(--divider);
    border-radius: 26px;
    padding: 28px 30px;
    box-shadow: var(--shadow-md);
    animation: rise .5s cubic-bezier(0, 0, .2, 1);
  }
  .success.on { display: block; }

  .success h3 {
    font-size: 18px;
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .success p {
    color: var(--text-2);
    font-size: 15px;
    margin-top: 8px;
    font-weight: 500;
  }

  .check {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--sage);
    display: grid;
    place-items: center;
    color: #fff;
    flex: none;
  }

  .field-error {
    font-size: 13px;
    font-weight: 600;
    color: var(--glow-coral);
    margin-top: 14px;
    padding-left: 8px;
    animation: rise .3s cubic-bezier(0,0,.2,1);
  }

  @media (max-width: 480px) {
    .field { flex-direction: column; border-radius: 20px; gap: 8px; }
    .field input { padding: 14px 18px; }
    .field button { width: 100%; justify-content: center; border-radius: 14px; }
  }
</style>
